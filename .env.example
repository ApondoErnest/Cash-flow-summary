# Cash Flow Summary — environment template (Step 16)
# Copy: cp .env.example .env && php artisan key:generate
# Set DB_PASSWORD locally. Never commit .env or local-db.env.

APP_NAME="Cash Flow Summary"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Africa/Douala

APP_LOCALE=en
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cashflow_summary
DB_USERNAME=cashflow_app
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Authentication security (Step 33)
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_DECAY_MINUTES=15
AUTH_SESSION_TIMEOUT_MINUTES=120
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_PASSWORD_MIXED_CASE=true
AUTH_PASSWORD_NUMBERS=true
AUTH_PASSWORD_SYMBOLS=true
AUTH_TWO_FACTOR_RECOVERY_CODES=8

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Horizon dashboard path (default: /horizon)
# HORIZON_PATH=horizon

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Report exports (Step 92) — private disk path exports/{center_id}/
EXPORTS_DISK=local
EXPORTS_TTL_HOURS=6
EXPORTS_CLEANUP_BATCH_SIZE=100

# Signed download URLs (Step 100)
DOWNLOAD_SIGNED_URL_TTL_MINUTES=30

# Production security hardening (Step 102) — enabled automatically when APP_ENV=production
# PRODUCTION_SECURITY_ENABLED=true
# FORCE_HTTPS=true
# TRUSTED_PROXIES=*
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax
# SECURITY_HSTS_ENABLED=true
# SECURITY_HSTS_MAX_AGE=31536000
# SECURITY_CSP_ENABLED=true

# CSV verification token TTL (minutes) — see docs/operations/setup.md
IMPORT_VERIFICATION_TTL_MINUTES=120

# Local dev: verify CSV inline without Horizon (default true when APP_ENV=local)
# CSV_VERIFICATION_SYNC=true

# Wave 1 seed (Step 31) — local dev only; change SEED_OWNER_PASSWORD in .env
SEED_OWNER_USERNAME=owner
SEED_OWNER_NAME=Owner
SEED_OWNER_PASSWORD=password

# WhatsApp Cloud API (Step 95–97) — Meta App Secret for webhook signature verification
# WHATSAPP_APP_SECRET=

# Import notifications — Meta template import_activity_summary (see docs/api/README.md)
# Language for activity summaries follows Organization Settings preferred language (en/fr).
# WHATSAPP_IMPORT_TEMPLATE=import_activity_summary
# WHATSAPP_IMPORT_TEMPLATE_LANGUAGE=en
# WHATSAPP_TEST_TEMPLATE=hello_world
# WHATSAPP_TEST_TEMPLATE_LANGUAGE=en_US
# WHATSAPP_DEFAULT_SUMMARY_TIME=18:00
